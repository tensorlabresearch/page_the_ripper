#!/usr/bin/env python3
"""Auto-detect SANE scanners and generate scanner.cfg."""

import argparse
import re
import shutil
import subprocess
import sys
from pathlib import Path

EXAMPLE_CFG = Path("/opt/page-the-ripper/scanner.cfg.example")


def run_scanimage(*args: str) -> str:
    """Run scanimage and return stdout, or empty string on failure."""
    try:
        result = subprocess.run(
            ["scanimage", *args],
            capture_output=True, text=True, timeout=30,
        )
        return result.stdout
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return ""


def list_devices() -> list[dict]:
    """Parse scanimage -L output into a list of device dicts."""
    raw = run_scanimage("-L")
    devices = []
    for line in raw.splitlines():
        # Format: device `epjitsu:libusb:001:004' is Fujitsu ScanSnap S1300i
        m = re.match(r"device\s+[`'](.+?)[']\s+is\s+(.+)", line)
        if m:
            devices.append({"device": m.group(1), "description": m.group(2)})
    return devices


def probe_capabilities(device: str) -> dict:
    """Probe a device for source and duplex capabilities."""
    raw = run_scanimage("-d", device, "-A")
    caps = {"source": "Flatbed", "duplex": False, "has_adf": False}

    for line in raw.splitlines():
        lower = line.lower()
        if "--source" in lower:
            if "adf" in lower:
                caps["has_adf"] = True
                if "duplex" in lower:
                    caps["duplex"] = True
                    caps["source"] = "ADF Duplex"
                else:
                    caps["source"] = "ADF Front"
            if "flatbed" in lower:
                caps["source"] = "Flatbed"

    # If device has ADF, prefer it as the source
    if caps["has_adf"]:
        if caps["duplex"]:
            caps["source"] = "ADF Duplex"
        else:
            caps["source"] = "ADF Front"

    return caps


def sanitize_key(description: str) -> str:
    """Turn a device description into a config section key."""
    key = re.sub(r"[^a-zA-Z0-9]+", "_", description).strip("_").lower()
    # Trim to reasonable length
    return key[:32] if key else "scanner"


def generate_config(devices: list[dict]) -> str:
    """Generate scanner.cfg content from detected devices."""
    lines = [
        "[defaults]",
        "dpi = 300",
        "color_mode = Grayscale8",
        "verify_ssl = false",
        "target_width = 405",
        "target_height = 636",
        "output_dir = /var/lib/page-the-ripper/scans",
        "",
    ]

    seen_keys: set[str] = set()
    for dev in devices:
        key = sanitize_key(dev["description"])
        # Deduplicate keys
        base_key = key
        counter = 2
        while key in seen_keys:
            key = f"{base_key}_{counter}"
            counter += 1
        seen_keys.add(key)

        caps = probe_capabilities(dev["device"])

        lines.extend([
            f"[scanner:{key}]",
            f"label = {dev['description']}",
            "backend = sane",
            f"sane_hint = {dev['device']}",
            "command =",
            f"source = {caps['source']}",
            f"duplex = {'true' if caps['duplex'] else 'false'}",
            "extra_args =",
            "color_mode = Grayscale8",
            "",
        ])

    return "\n".join(lines) + "\n"


def main() -> None:
    parser = argparse.ArgumentParser(description="Detect SANE scanners")
    parser.add_argument(
        "--output", "-o",
        default="/etc/page-the-ripper/scanner.cfg",
        help="Output path for scanner.cfg",
    )
    args = parser.parse_args()

    output = Path(args.output)
    output.parent.mkdir(parents=True, exist_ok=True)

    devices = list_devices()
    if devices:
        print(f"Detected {len(devices)} scanner(s):")
        for d in devices:
            print(f"  - {d['description']} ({d['device']})")
        output.write_text(generate_config(devices))
        print(f"Wrote {output}")
    else:
        print("No scanners detected. Installing example config.")
        if EXAMPLE_CFG.exists():
            shutil.copy2(EXAMPLE_CFG, output)
        else:
            # Minimal fallback
            output.write_text(generate_config([]))
        print(f"Wrote {output}")


if __name__ == "__main__":
    main()
